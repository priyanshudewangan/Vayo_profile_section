# ==========================================
# VAYO Backend - Git Ignore Specifications
# ==========================================

# 1. Environment & Sensitive Configs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
! .env.example

# 2. Virtual Environments & Packages
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/

# 3. Python Cache & Compilation
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# 4. User Requested Folders to Ignore
tests/
docs/

# 5. IDE & Editor Specific Configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# 6. Operating System & IDE Artifacts
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride
scratch/
